@page "/"
@using Dashboard.Services
@inject ClusterApiService Api
@implements IDisposable

<PageTitle>SimCluster Dashboard</PageTitle>

<div class="dashboard">
    <h2>SimCluster Dashboard</h2>

    @if (_stats != null)
    {
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-value">@_workers.Count</div>
                <div class="stat-label">Workers</div>
            </div>
            <div class="stat-card pending">
                <div class="stat-value">@_stats.Pending</div>
                <div class="stat-label">Pending</div>
            </div>
            <div class="stat-card running">
                <div class="stat-value">@_stats.Running</div>
                <div class="stat-label">Running</div>
            </div>
            <div class="stat-card completed">
                <div class="stat-value">@_stats.Completed</div>
                <div class="stat-label">Completed</div>
            </div>
            <div class="stat-card failed">
                <div class="stat-value">@_stats.Failed</div>
                <div class="stat-label">Failed</div>
            </div>
        </div>
    }

    <div class="submit-section">
        <h4>Submit Task</h4>
        <div class="submit-form">
            <input @bind="_newTaskName" placeholder="Task name" />
            <input @bind="_newTaskDuration" type="number" placeholder="Duration (ms)" />
            <select @bind="_newTaskPriority">
                <option value="0">Low</option>
                <option value="1">Normal</option>
                <option value="2">High</option>
            </select>
            <button class="btn-submit" @onclick="SubmitTask" disabled="@_submitting">
                @(_submitting ? "Sending..." : "Submit")
            </button>
            <button class="btn-submit btn-batch" @onclick="SubmitBatch" disabled="@_submitting">
                Send 1000 tasks
            </button>
        </div>
    </div>

    <div class="panels">
        <div class="panel">
            <div class="panel-header">
                <h4>Workers (@_workers.Count)</h4>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>URL</th>
                        <th>Status</th>
                        <th>Free Threads</th>
                        <th>Last Heartbeat</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var w in _workers)
                    {
                        <tr class="@(!w.IsEnabled ? "row-disabled" : "")">
                            <td class="mono">@w.WorkerId[..Math.Min(12, w.WorkerId.Length)]</td>
                            <td class="mono">@w.Url</td>
                            <td>
                                @if (!w.IsEnabled)
                                {
                                    <span class="badge badge-disabled">Disabled</span>
                                }
                                else
                                {
                                    <span class="badge @(w.IsAvailable && w.IsReady ? "badge-completed" : "badge-failed")">
                                        @(w.IsAvailable && w.IsReady ? "Ready" : "Offline")
                                    </span>
                                }
                            </td>
                            <td>@w.FreeThreads</td>
                            <td>@w.LastHeartbeat.ToString("HH:mm:ss")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="panel">
            <h4>Tasks (@_tasks.Count)</h4>
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Priority</th>
                        <th>Worker</th>
                        <th>Duration</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in _tasks.Take(50))
                    {
                        <tr>
                            <td>@t.Name</td>
                            <td><span class="badge @t.StatusCss">@t.StatusLabel</span></td>
                            <td>@t.PriorityLabel</td>
                            <td class="mono">@(t.AssignedWorkerId?[..Math.Min(12, t.AssignedWorkerId?.Length ?? 0)] ?? "-")</td>
                            <td>@(t.DurationMs)ms</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<WorkerDto> _workers = [];
    private List<TaskDto> _tasks = [];
    private TaskStatsDto? _stats;
    private Timer? _timer;

    private string _newTaskName = "";
    private int _newTaskDuration = 3000;
    private int _newTaskPriority = 1;
    private bool _submitting;
    private bool _scaling;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
        _timer = new Timer(async _ =>
        {
            await Refresh();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    private async Task Refresh()
    {
        var workersResp = await Api.GetWorkersAsync();
        var tasksResp = await Api.GetTasksAsync();

        if (workersResp != null) _workers = workersResp.Workers;
        if (tasksResp != null)
        {
            _tasks = tasksResp.Tasks;
            _stats = tasksResp.Stats;
        }
    }

    private async Task SubmitTask()
    {
        if (string.IsNullOrWhiteSpace(_newTaskName)) return;
        _submitting = true;
        await Api.SubmitTaskAsync(new TaskSubmitRequest
        {
            Name = _newTaskName,
            DurationMs = _newTaskDuration,
            Priority = _newTaskPriority
        });
        _newTaskName = "";
        await Refresh();
        _submitting = false;
    }

    private async Task SubmitBatch()
    {
        _submitting = true;
        var rng = new Random();
        for (int i = 1; i <= 1000; i++)
        {
            await Api.SubmitTaskAsync(new TaskSubmitRequest
            {
                Name = $"Batch-{DateTime.UtcNow:HHmmss}-{i}",
                DurationMs = rng.Next(1000, 8000),
                Priority = rng.Next(0, 3)
            });
        }
        await Refresh();
        _submitting = false;
    }

    public void Dispose() => _timer?.Dispose();
}